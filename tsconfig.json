{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "sourceMap": true,
    "declaration": false,
    "module": "esnext",
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2022",
    "useDefineForClassFields": false,
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "es2018",
      "dom"
    ],
    "skipLibCheck": true,
    "strict": false
  },
  "exclude": [
    "node_modules",
    "out-tsc",
    "**/*.spec.ts"
  ]
}
